# Place this file in robot-accomplice/roboticus/.github/workflows/notify-goboticus.yml
#
# Requires a PAT with repo scope stored as ROBOTICUS_DISPATCH_TOKEN secret
# in the roboticus repo settings.

name: Notify Goboticus of Release

on:
  release:
    types: [published]
  push:
    tags:
      - 'v*'

jobs:
  notify:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger goboticus parity audit
        env:
          GH_TOKEN: ${{ secrets.ROBOTICUS_DISPATCH_TOKEN }}
        run: |
          set -euo pipefail
          gh api \
            --method POST \
            -H "Accept: application/vnd.github+json" \
            repos/robot-accomplice/goboticus/dispatches \
            -f event_type=roboticus-release \
            -F client_payload[tag]='${{ github.ref_name }}' \
            -F client_payload[release_name]='${{ github.event.release.name || github.ref_name }}' \
            -F client_payload[sha]='${{ github.sha }}'
